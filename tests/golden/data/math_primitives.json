{
  "description": "MathML leaf nodes — mi (variables), mn (numbers), mo (operators / relations / delims / punctuation), mtext.",
  "regen_hint": "python -c \"from brailix import Pipeline; print(repr(Pipeline().translate_text(SRC).render()))\"",
  "groups": {
    "mi": {
      "description": "<mi> identifiers — latin / greek, upper and lower case",
      "cases": [
        {"src": "$x$", "expected": "⠰⠭", "note": "single lowercase latin x: latin_lower prefix(56) + x(1346)"},
        {"src": "$y$", "expected": "⠰⠽", "note": "single lowercase latin y"},
        {"src": "$z$", "expected": "⠰⠵", "note": "single lowercase latin z"},
        {"src": "$a$", "expected": "⠰⠁", "note": "single lowercase latin a"},
        {"src": "$b$", "expected": "⠰⠃", "note": "single lowercase latin b"},
        {"src": "$c$", "expected": "⠰⠉", "note": "single lowercase latin c"},
        {"src": "$d$", "expected": "⠰⠙", "note": "single lowercase latin d"},
        {"src": "$e$", "expected": "⠰⠑", "note": "single lowercase latin e"},
        {"src": "$f$", "expected": "⠰⠋", "note": "single lowercase latin f"},
        {"src": "$n$", "expected": "⠰⠝", "note": "single lowercase latin n"},
        {"src": "$A$", "expected": "⠠⠁", "note": "single uppercase latin A: latin_upper prefix(6) + a"},
        {"src": "$B$", "expected": "⠠⠃", "note": "single uppercase latin B"},
        {"src": "$X$", "expected": "⠠⠭", "note": "single uppercase latin X"},
        {"src": "$Z$", "expected": "⠠⠵", "note": "single uppercase latin Z"},
        {"src": "$\\pi$", "expected": "⠨⠏", "note": "greek lower pi: greek_lower prefix(46) + π"},
        {"src": "$\\alpha$", "expected": "⠨⠁", "note": "greek lower alpha"},
        {"src": "$\\beta$", "expected": "⠨⠃", "note": "greek lower beta"},
        {"src": "$\\gamma$", "expected": "⠨⠛", "note": "greek lower gamma"},
        {"src": "$\\theta$", "expected": "⠨⠹", "note": "greek lower theta"},
        {"src": "$\\omega$", "expected": "⠨⠺", "note": "greek lower omega"},
        {"src": "$\\lambda$", "expected": "⠨⠇", "note": "greek lower lambda"},
        {"src": "$\\sigma$", "expected": "⠨⠎", "note": "greek lower sigma"},
        {"src": "$\\mu$", "expected": "⠨⠍", "note": "greek lower mu"},
        {"src": "$\\Delta$", "expected": "⠸⠙", "note": "greek upper Delta: greek_upper prefix(456) + Δ"},
        {"src": "$\\Gamma$", "expected": "⠸⠛", "note": "greek upper Gamma"},
        {"src": "$\\Omega$", "expected": "⠸⠺", "note": "greek upper Omega"},
        {"src": "$\\Sigma$", "expected": "⠸⠎", "note": "greek upper Sigma"},
        {"src": "$\\Pi$", "expected": "⠸⠏", "note": "greek upper Pi"}
      ]
    },
    "mn": {
      "description": "<mn> numbers — single digit / multi-digit / decimal / thousands separator",
      "cases": [
        {"src": "$0$", "expected": "⠼⠚", "note": "single digit 0 with number_sign"},
        {"src": "$1$", "expected": "⠼⠁", "note": "single digit 1"},
        {"src": "$2$", "expected": "⠼⠃", "note": "single digit 2"},
        {"src": "$3$", "expected": "⠼⠉", "note": "single digit 3"},
        {"src": "$4$", "expected": "⠼⠙", "note": "single digit 4"},
        {"src": "$5$", "expected": "⠼⠑", "note": "single digit 5"},
        {"src": "$6$", "expected": "⠼⠋", "note": "single digit 6"},
        {"src": "$7$", "expected": "⠼⠛", "note": "single digit 7"},
        {"src": "$8$", "expected": "⠼⠓", "note": "single digit 8"},
        {"src": "$9$", "expected": "⠼⠊", "note": "single digit 9"},
        {"src": "$10$", "expected": "⠼⠁⠚", "note": "two-digit run: one number_sign for run"},
        {"src": "$42$", "expected": "⠼⠙⠃", "note": "two-digit 42"},
        {"src": "$99$", "expected": "⠼⠊⠊", "note": "two-digit 99"},
        {"src": "$100$", "expected": "⠼⠁⠚⠚", "note": "three-digit 100"},
        {"src": "$1234$", "expected": "⠼⠁⠃⠉⠙", "note": "four-digit 1234"},
        {"src": "$3.14$", "expected": "⠼⠉⠂⠁⠙", "note": "decimal: number_sign + 3 + decimal_point + 14"},
        {"src": "$0.5$", "expected": "⠼⠚⠂⠑", "note": "decimal less than one"},
        {"src": "$2.71828$", "expected": "⠼⠃⠂⠛⠁⠓⠃⠓", "note": "long decimal"},
        {"src": "$1,000$", "expected": "⠼⠁⠐⠚⠚⠚", "note": "thousands comma ⠐ tight, no space"},
        {"src": "$1,000,000$", "expected": "⠼⠁⠐⠚⠚⠚⠐⠚⠚⠚", "note": "two tight thousands commas ⠐"}
      ]
    },
    "mo": {
      "description": "<mo> operators / relations / delimiters / punctuation / shapes — spacing rules live in symbols.json",
      "cases": [
        {"src": "$a + b$", "expected": "⠰⠁⠀⠖⠰⠃", "note": "plus op with space_before"},
        {"src": "$a - b$", "expected": "⠰⠁⠀⠤⠰⠃", "note": "minus op"},
        {"src": "$a \\times b$", "expected": "⠰⠁⠀⠦⠰⠃", "note": "times op"},
        {"src": "$a \\div b$", "expected": "⠰⠁⠀⠲⠰⠃", "note": "divide op"},
        {"src": "$a \\cdot b$", "expected": "⠰⠁⠄⠰⠃", "note": "cdot has NO space"},
        {"src": "$a \\pm b$", "expected": "⠰⠁⠀⠖⠤⠰⠃", "note": "plusmn: plus + minus with space_before"},
        {"src": "$a \\mp b$", "expected": "⠰⠁⠀⠤⠖⠰⠃", "note": "mnplus: minus + plus"},
        {"src": "$a = b$", "expected": "⠰⠁⠀⠶⠰⠃", "note": "equals (rel role)"},
        {"src": "$a < b$", "expected": "⠰⠁⠀⠪⠀⠰⠃", "note": "less than — spaced both sides"},
        {"src": "$a > b$", "expected": "⠰⠁⠀⠕⠀⠰⠃", "note": "greater than — spaced both sides"},
        {"src": "$a \\leq b$", "expected": "⠰⠁⠀⠪⠶⠰⠃", "note": "≤ = lt + equals"},
        {"src": "$a \\geq b$", "expected": "⠰⠁⠀⠕⠶⠰⠃", "note": "≥ = gt + equals"},
        {"src": "$a \\neq b$", "expected": "⠰⠁⠀⠈⠶⠰⠃", "note": "≠ = not + equals"},
        {"src": "$a \\approx b$", "expected": "⠰⠁⠀⠢⠢⠰⠃", "note": "≈ ⠢⠢"},
        {"src": "$a \\equiv b$", "expected": "⠰⠁⠀⠰⠶⠰⠃", "note": "≡ ⠰⠶"},
        {"src": "$a \\cong b$", "expected": "⠰⠁⠀⠔⠶⠰⠃", "note": "congruent ≅ ⠔⠶"},
        {"src": "$a \\ncong b$", "expected": "⠰⠁⠀⠈⠔⠶⠰⠃", "note": "not congruent"},
        {"src": "$x \\in A$", "expected": "⠰⠭⠀⠐⠪⠀⠠⠁", "note": "∈ ⠐⠪ spaced both sides"},
        {"src": "$a \\parallel b$", "expected": "⠰⠁⠀⠇⠇⠰⠃", "note": "parallel ∥ ⠇⠇"},
        {"src": "$a \\mid b$", "expected": "⠰⠁⠀⠇⠰⠃", "note": "divides (整除) ∣ ⠇ — space before, none after"},
        {"src": "$a \\nmid b$", "expected": "⠰⠁⠈⠇⠰⠃", "note": "does not divide (不整除) ∤ ⠈⠇ — no surrounding space"},
        {"src": "$A \\rightarrow B$", "expected": "⠠⠁⠀⠒⠕⠠⠃", "note": "→ ⠒⠕"},
        {"src": "$A \\leftarrow B$", "expected": "⠠⠁⠀⠪⠒⠠⠃", "note": "← ⠪⠒"},
        {"src": "$A \\Rightarrow B$", "expected": "⠠⠁⠀⠶⠜⠠⠃", "note": "⇒ implies ⠶⠜"},
        {"src": "$A \\Leftrightarrow B$", "expected": "⠠⠁⠀⠣⠶⠜⠠⠃", "note": "⇔ equivalent ⠣⠶⠜"},
        {"src": "$\\because a$", "expected": "⠡⠁⠰⠁", "note": "because ∵ ⠡⠁"},
        {"src": "$\\therefore a$", "expected": "⠌⠄⠰⠁", "note": "therefore ∴ ⠌⠄"},
        {"src": "$\\infty$", "expected": "⠼⠿", "note": "∞ ⠼⠿"},
        {"src": "$(x)$", "expected": "⠣⠰⠭⠜", "note": "paren delims"},
        {"src": "$[x]$", "expected": "⠷⠰⠭⠾", "note": "bracket delims"},
        {"src": "$\\{x\\}$", "expected": "⠪⠰⠭⠕", "note": "brace delims"},
        {"src": "$a, b$", "expected": "⠰⠁⠐⠀⠰⠃", "note": "math comma dot-5 ⠐ with space_after"},
        {"src": "$(1, 2)$", "expected": "⠣⠼⠁⠐⠀⠼⠃⠜", "note": "numeric coordinate: each list element restarts the number sign (the 2 is a number, not the letter b); the comma keeps its space (not a thousands group)"}
      ]
    },
    "mo_set_logic": {
      "description": "<mo> set theory / logic / calculus / inequality extensions",
      "cases": [
        {"src": "$A \\subset B$", "expected": "⠠⠁⠀⠯⠀⠠⠃", "note": "proper subset of ⊂ ⠯ — spaced both sides"},
        {"src": "$A \\supset B$", "expected": "⠠⠁⠀⠹⠀⠠⠃", "note": "proper superset of ⊃ ⠹ — spaced both sides"},
        {"src": "$A \\subseteq B$", "expected": "⠠⠁⠀⠯⠶⠠⠃", "note": "subset of or equal ⊆ ⠯⠶ — space before, none after"},
        {"src": "$A \\supseteq B$", "expected": "⠠⠁⠀⠹⠶⠠⠃", "note": "superset of or equal ⊇ ⠹⠶ — space before, none after"},
        {"src": "$x \\notin A$", "expected": "⠰⠭⠘⠪⠠⠁", "note": "not an element of ∉ ⠘⠪ — no surrounding space"},
        {"src": "$A \\cup B$", "expected": "⠠⠁⠀⠰⠴⠠⠃", "note": "union ∪ ⠰⠴ — space before, none after"},
        {"src": "$A \\cap B$", "expected": "⠠⠁⠀⠰⠲⠠⠃", "note": "intersection ∩ ⠰⠲ — space before, none after"},
        {"src": "$a \\setminus b$", "expected": "⠰⠁⠰⠤⠰⠃", "note": "set difference — \\setminus produces U+29F5(⧵), matches ∖ ⠰⠤ via the U+29F5 alias"},
        {"src": "$a \\smallsetminus b$", "expected": "⠰⠁⠰⠤⠰⠃", "note": "set difference — \\smallsetminus produces ∖ U+2216 ⠰⠤"},
        {"src": "$x = \\emptyset$", "expected": "⠰⠭⠀⠶⠈⠴", "note": "empty set ∅ ⠈⠴"},
        {"src": "$p \\wedge q$", "expected": "⠰⠏⠀⠰⠢⠰⠟", "note": "conjunction (and) ∧ ⠰⠢"},
        {"src": "$p \\vee q$", "expected": "⠰⠏⠀⠰⠔⠰⠟", "note": "disjunction (or) ∨ ⠰⠔"},
        {"src": "$\\neg p$", "expected": "⠩⠰⠏", "note": "negation (not) ¬ ⠩"},
        {"src": "$\\forall x$", "expected": "⠫⠄⠰⠭", "note": "universal quantifier ∀ ⠫⠄"},
        {"src": "$\\exists x$", "expected": "⠫⠢⠰⠭", "note": "existential quantifier ∃ ⠫⠢"},
        {"src": "$a \\ll b$", "expected": "⠰⠁⠀⠪⠪⠀⠰⠃", "note": "much less than ≪ ⠪⠪ — spaced both sides"},
        {"src": "$a \\gg b$", "expected": "⠰⠁⠀⠕⠕⠀⠰⠃", "note": "much greater than ≫ ⠕⠕ — spaced both sides"},
        {"src": "$a \\nless b$", "expected": "⠰⠁⠀⠈⠪⠀⠰⠃", "note": "not less than ≮ ⠈⠪ — spaced both sides"},
        {"src": "$a \\ngtr b$", "expected": "⠰⠁⠀⠈⠕⠀⠰⠃", "note": "not greater than ≯ ⠈⠕ — spaced both sides"},
        {"src": "$\\partial f$", "expected": "⠹⠰⠋", "note": "partial derivative ∂ ⠹ — no surrounding space"},
        {"src": "$\\nabla f$", "expected": "⠫⠴⠰⠋", "note": "nabla ∇ ⠫⠴"},
        {"src": "$\\iint f$", "expected": "⠮⠮⠰⠋", "note": "double integral ∬ ⠮⠮ (bare, no limits)"},
        {"src": "$\\iiint f$", "expected": "⠮⠮⠮⠰⠋", "note": "triple integral ∭ ⠮⠮⠮ (bare, no limits)"},
        {"src": "$\\langle x \\rangle$", "expected": "⠐⠪⠰⠭⠕⠂", "note": "angle brackets ⟨⟩ ⠐⠪…⠕⠂ — delim no space"},
        {"src": "$a \\lessgtr b$", "expected": "⠰⠁⠀⠪⠕⠀⠰⠃", "note": "less than or greater than ≶ ⠪⠕ = lt+gt — spaced both sides"},
        {"src": "$a \\gtrless b$", "expected": "⠰⠁⠀⠕⠪⠀⠰⠃", "note": "greater than or less than ≷ ⠕⠪ = gt+lt — spaced both sides"},
        {"src": "$A \\not\\subset B$", "expected": "⠠⠁⠈⠯⠠⠃", "note": "not a subset of ⊄ ⠈⠯ = not+proper subset of — no surrounding space"},
        {"src": "$A \\not\\supset B$", "expected": "⠠⠁⠈⠹⠠⠃", "note": "not a superset of ⊅ ⠈⠹ = not+proper superset of — no surrounding space"}
      ]
    },
    "mtext": {
      "description": "<mtext> / \\text{...} is natural-language text, routed through the zh/latin language path: one letter prefix per word (not per char), Chinese as Chinese braille, spaces (incl. the U+00A0 latex2mathml emits inside \\text) as blank cells",
      "cases": [
        {"src": "$\\text{ab}$", "expected": "⠰⠁⠃", "note": "mtext word: one latin prefix for the run, not one per char"},
        {"src": "$\\text{x}$", "expected": "⠰⠭", "note": "mtext single char x"},
        {"src": "$\\text{hello}$", "expected": "⠰⠓⠑⠇⠇⠕", "note": "mtext word hello: single latin prefix"},
        {"src": "$\\text{a b}$", "expected": "⠰⠁⠀⠰⠃", "note": "mtext space (latex2mathml gives U+00A0) → blank cell, no warning"},
        {"src": "$\\text{速度}$", "expected": "⠎⠥⠆⠙⠥⠆", "note": "mtext Chinese → Chinese braille via the language path (was blank cells)"}
      ]
    }
  }
}
