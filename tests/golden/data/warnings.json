{
  "description": "Warning-code tests — malformed input must carry a specific code, clean input must emit no noise warnings.",
  "regen_hint": "python -c \"from brailix import Pipeline; r = Pipeline().translate_text(SRC); print(repr(r.render())); print([w.code for w in r.warnings])\"",
  "groups": {
    "warning_emit": {
      "description": "Malformed input: output is recoverable, and the specified warning code must be emitted",
      "cases": [
        {
          "src": "$\\unknownfoo$",
          "expected": "⠫⠰⠥⠝⠅⠝⠕⠺⠝⠋⠕⠕",
          "note": "unknown control sequence: backslash stripped + spelled name; the lowercase run shares one ⠰, no warning"
        },
        {
          "src": "$\\circ$",
          "expected": "⠀",
          "warnings_include": ["MATH_UNKNOWN_SYMBOL"],
          "note": "circ (∘) is not in symbols table"
        },
        {
          "src": "$☃$",
          "expected": "⠀",
          "warnings_include": ["MATH_UNKNOWN_IDENTIFIER"],
          "note": "snowman: unicode char with no math mapping"
        },
        {
          "id": "hat-empty-warn",
          "src": "$\\hat{x}$",
          "expected": "⠰⠭⠘⠀",
          "warnings_include": ["MATH_UNKNOWN_SYMBOL"],
          "note": "hat accent ^ not yet recorded → above marker ⠘ + unknown cell + MATH_UNKNOWN_SYMBOL"
        },
        {
          "id": "double-dollar-empty",
          "src": "$$",
          "expected": "⠀⠀",
          "warnings_include": ["UNKNOWN_PUNCT"],
          "note": "empty $$ — two unknown punct cells, only one unique code"
        },
        {
          "src": "$\\heartsuit$",
          "expected": "⠀",
          "warnings_include": ["MATH_UNKNOWN_IDENTIFIER"],
          "note": "\\heartsuit (♡ U+2661): decorative symbol, not a math notation → unknown identifier + blank-cell recovery. (was \\triangle, but △ is now recorded as a geometric shape, so switched to a still-unknown symbol)"
        },
        {
          "id": "spadesuit-unknown",
          "src": "$\\spadesuit$",
          "expected": "⠀",
          "warnings_include": ["MATH_UNKNOWN_IDENTIFIER"],
          "note": "\\spadesuit (♠ U+2660): as above, another unknown decorative symbol (kept as a second case to maintain the warning case count)"
        }
      ]
    },
    "clean_inputs": {
      "description": "well-formed input: must not trigger any recovery noise warnings",
      "cases": [
        {"src": "$x$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean math var x"},
        {"src": "$y$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean math var y"},
        {"src": "$\\pi$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean greek pi"},
        {"src": "$\\alpha$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean greek alpha"},
        {"src": "$\\Delta$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean greek upper Delta"},
        {"src": "$5$", "warnings_exclude": ["MATH_UNKNOWN_IDENTIFIER", "MATH_UNKNOWN_SYMBOL", "MATH_UNKNOWN_DIGIT", "MATH_UNKNOWN_TEXT_CHAR", "MATH_MISSING_NUMBER_PART", "MATH_UNSUPPORTED_ELEMENT", "MATH_NO_IR", "MATH_ERROR", "UNKNOWN_PUNCT", "MISSING_FINAL", "UNHANDLED_SEGMENT_TYPE"], "note": "clean math digit 5"},
